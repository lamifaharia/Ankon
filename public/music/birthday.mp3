import { useRef, useState } from "react";
import { FaPause, FaPlay, FaMusic } from "react-icons/fa";

const MusicPlayer = () => {
  const audioRef = useRef(null);

  const [playing, setPlaying] = useState(false);

  const toggleMusic = () => {
    if (!playing) {
      audioRef.current.play();
    } else {
      audioRef.current.pause();
    }

    setPlaying(!playing);
  };

  return (
    <>
      <audio
        ref={audioRef}
        loop
        src="/music/birthday.mp3"
      />

      <button
        onClick={toggleMusic}
        className="fixed bottom-8 right-8 z-50 backdrop-blur-xl bg-white/10 border border-white/10 rounded-full w-16 h-16 flex items-center justify-center shadow-[0_20px_60px_rgba(0,0,0,.35)] hover:scale-110 duration-300"
      >
        {playing ? (
          <FaPause className="text-white text-xl" />
        ) : (
          <FaPlay className="text-white text-xl ml-1" />
        )}
      </button>

      {!playing && (
        <div className="fixed bottom-28 right-8 bg-white/10 backdrop-blur-xl border border-white/10 rounded-2xl px-4 py-3 text-sm text-gray-200 z-50 flex items-center gap-2">
          <FaMusic />
          Play our soundtrack 🎵
        </div>
      )}
    </>
  );
};

export default MusicPlayer;